{
    "name": "Instagram Plus",
    "description": "Extra controls for Instagram videos, reels, stories, and posts.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": ["storage", "tabs"],
    "host_permissions": [
        "https://instagram.com/*",
        "https://www.instagram.com/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        },
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": [
                "https://instagram.com/*",
                "https://www.instagram.com/*"
            ],
            "js": ["instagram.js"],
            "css": ["instagram.css"]
        }
    ]
}
